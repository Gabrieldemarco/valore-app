# ========== BASE ==========
NODE_ENV=production
PORT=3000
DATABASE_URL=postgresql://user:password@localhost:5432/agenda_app_db
JWT_SECRET=genera_un_seguro_aqui
DB_SSL_REJECT_UNAUTHORIZED=true
WEBHOOK_RATE_LIMIT_MAX=30
INCLUDE_ERROR_DETAILS=false

# ========== CORS ==========
# Use dominios específicos. No uses * en producción.
ALLOWED_ORIGINS=https://tudominio.com,https://www.tudominio.com

# ========== MERCADOPAGO ==========
MP_PUBLIC_KEY=
MP_ACCESS_TOKEN=
MP_WEBHOOK_SECRET=
MP_CURRENCY=UYU
MP_LOCALE=es-UY
MP_COUNTRY=UY

# ========== PLANES ==========
PLAN_PRO_PRICE=990
PLAN_ENTERPRISE_PRICE=2490

# ========== SMTP (email notifications) ==========
SMTP_SERVICE=Gmail
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=tu-email@gmail.com
SMTP_PASS=tu-app-password

# ========== TWILIO (WhatsApp) ==========
# Número de WhatsApp Business verificado en Twilio (con código de país, ej: +14155238886)
TWILIO_WHATSAPP_FROM=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# ========== PUSH NOTIFICATIONS ==========
# Generar con: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# ========== OPCIONAL ==========
BASE_URL=https://tudominio.com
LOG_LEVEL=info
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.2
BCRYPT_ROUNDS=12
JWT_ALGORITHM=HS256
METRICS_ENABLED=true
SWAGGER_UI_ENABLED=true
SWAGGER_BASIC_AUTH_USER=admin
SWAGGER_BASIC_AUTH_PASS=tu-password-segura
SWAGGER_UI_ROUTE=/api-docs
SWAGGER_UI_JSON_ROUTE=/api-docs.json
METRICS_BASIC_AUTH_USER=metrics
METRICS_BASIC_AUTH_PASS=tu-password-segura
SEED_DEMO=false
DB_POOL_MAX=30

# ========== TEST ==========
TEST_DATABASE_URL=postgresql://postgres:password@localhost:5433/agenda_app_test
