# ========== BASE ==========
NODE_ENV=production
PORT=3000
DATABASE_URL=postgresql://user:password@localhost:5432/agenda_app_db
JWT_SECRET=genera_un_seguro_aqui

# ========== CORS ==========
ALLOWED_ORIGINS=https://tudominio.com,https://www.tudominio.com

# ========== MERCADOPAGO ==========
MP_PUBLIC_KEY=
MP_ACCESS_TOKEN=
MP_WEBHOOK_SECRET=
MP_CURRENCY=UYU
MP_LOCALE=es-UY
MP_COUNTRY=UY

# ========== PLANES ==========
PLAN_PRO_PRICE=990
PLAN_ENTERPRISE_PRICE=2490

# ========== SMTP (email notifications) ==========
SMTP_SERVICE=Gmail
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=tu-email@gmail.com
SMTP_PASS=tu-app-password

# ========== TWILIO (WhatsApp) ==========
# Número de WhatsApp Business verificado en Twilio (con código de país, ej: +14155238886)
TWILIO_WHATSAPP_FROM=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# ========== OPCIONAL ==========
BASE_URL=https://tudominio.com
LOG_LEVEL=info
SEED_DEMO=false

# ========== TEST ==========
TEST_DATABASE_URL=postgresql://postgres:password@localhost:5433/agenda_app_test
