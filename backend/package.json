{
  "name": "agenda-backend",
  "version": "1.0.0",
  "main": "server.js",
  "scripts": {
    "start": "tsx server.ts",
    "test": "cross-env NODE_ENV=test jest --runInBand --forceExit",
    "test:integration": "cross-env NODE_ENV=test jest --runInBand --forceExit --config jest.integration.config.js",
    "test:e2e": "npx playwright test --config tests/e2e/playwright.config.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^4.22.2",
    "express-rate-limit": "^8.0.0",
    "express-validator": "^7.3.2",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "mercadopago": "^2.12.1",
    "morgan": "^1.10.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.7",
    "pg": "^8.20.0",
    "sanitize-html": "^2.17.4",
    "twilio": "^6.0.0",
    "uuid": "^9.0.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "jest": "^30.4.2",
    "supertest": "^7.2.2"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/*.test.js"
    ],
    "transform": {
      "^.+\\.ts$": "ts-jest"
    },
    "moduleFileExtensions": ["ts", "js", "json"],
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    }
  }
}
